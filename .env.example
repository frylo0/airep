# Адрес, пользователь и каталог сайта на VPS.
DEPLOY_HOST=example.com
DEPLOY_USER=deploy
DEPLOY_PATH=/var/www/airep

# SSH-порт и необязательный путь к приватному ключу.
DEPLOY_PORT=22

# Пароль заключайте в одинарные кавычки, особенно если в нём есть спецсимволы.
DEPLOY_PASSWORD='change-me'

# Необязательно: оставьте пустым, если подключаетесь только по паролю.
DEPLOY_SSH_KEY=

# true удалит на VPS файлы, которых больше нет в локальной сборке.
DEPLOY_DELETE=false
